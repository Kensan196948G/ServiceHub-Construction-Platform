# ========================================
# ServiceHub Construction Platform
# 環境変数設定ファイル（.env.exampleをコピーして.envを作成）
# cp .env.example .env
# ========================================

# ── アプリケーション ────────────────────
ENVIRONMENT=development        # development / staging / production
APP_NAME=ServiceHub Construction Platform
APP_VERSION=0.1.0
LOG_LEVEL=DEBUG                # DEBUG / INFO / WARNING / ERROR

# ── セキュリティ ────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── データベース ────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=servicehub
DB_PASSWORD=servicehub_pass
DB_NAME=servicehub_db
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis ───────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ── MinIO (ファイルストレージ) ───────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_PHOTOS=servicehub-photos
MINIO_BUCKET_DOCS=servicehub-docs
MINIO_USE_SSL=false

# ── AI設定 ─────────────────────────────
# 注意: 本番環境ではシークレット管理ツールを使用すること
OPENAI_API_KEY=your-openai-api-key-here
AI_MAX_TOKENS=4096
AI_RATE_LIMIT=100

# ── フロントエンド ──────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=ServiceHub Construction Platform

# ── CORS ───────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ── タイムゾーン ────────────────────────
TZ=Asia/Tokyo
