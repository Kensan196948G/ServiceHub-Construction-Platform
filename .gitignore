# ServiceHub Construction Platform - .gitignore

# ── 環境変数（シークレット） ─────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Node.js ──────────────────────────────────────────
node_modules/
dist/
.next/
out/
.nuxt/
.cache/
*.local

# ── Docker ───────────────────────────────────────────
uploads/

# ── IDE ──────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.DS_Store
._*
Thumbs.db

# ── Claude Code (local dev config) ───────────────────
.claude/

# ── ログ ─────────────────────────────────────────────
*.log
logs/

# ── Playwright ───────────────────────────────────────
/frontend/test-results/
/frontend/playwright-report/
/frontend/blob-report/
/frontend/playwright/.cache/

# ── ビルド成果物 ─────────────────────────────────────
*.pyc

# ── Helm ─────────────────────────────────────────────
charts/servicehub/charts/*.tgz
charts/servicehub/Chart.lock
