# ===================================================
# ServiceHub Construction Platform - 本番環境設定
# ===================================================
# このファイルを .env.prod にコピーして値を設定してください
# cp .env.prod.example .env.prod

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://servicehub:CHANGE_ME_DB_PASSWORD@db:5432/servicehub
POSTGRES_DB=servicehub
POSTGRES_USER=servicehub
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ---- Redis ----
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- JWT (必ず32文字以上の強力なランダム文字列に変更) ----
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_32CHARS_MINIMUM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- MinIO ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET_NAME=servicehub-files
MINIO_USE_SSL=false

# ---- OpenAI (任意: AI検索機能) ----
OPENAI_API_KEY=

# ---- App ----
ENVIRONMENT=production
ALLOWED_ORIGINS=https://your-domain.example.com
LOG_LEVEL=INFO
